\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Representative position-error and $3\sigma $ consistency check for the estimate-tracking baseline. The component errors remain within the estimated covariance envelope after the early transient, supporting the NEES/NIS consistency claims.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:pos3sigma}{{5}{7}{Representative position-error and $3\sigma $ consistency check for the estimate-tracking baseline. The component errors remain within the estimated covariance envelope after the early transient, supporting the NEES/NIS consistency claims}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Navigation-error to burn-error coupling map for the representative cislunar baseline. Terminal miss and relative $\Delta V$ inflation increase rapidly with the correction-time position-error scale, showing why navigation performance should be evaluated at the guidance output.}}{8}{figure.6}\protected@file@percent }
\newlabel{fig:coupling}{{6}{8}{Navigation-error to burn-error coupling map for the representative cislunar baseline. Terminal miss and relative $\Delta V$ inflation increase rapidly with the correction-time position-error scale, showing why navigation performance should be evaluated at the guidance output}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Fixed and active pointing comparison. Fixed pointing loses target visibility and produces estimator divergence, while estimate-driven pointing maintains measurement availability and bounded estimation error.}}{8}{figure.7}\protected@file@percent }
