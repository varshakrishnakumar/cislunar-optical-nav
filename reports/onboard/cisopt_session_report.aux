\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Estimator consistency: NEES, not miss}{4}{subsection.5.1}\protected@file@percent }
\newlabel{sec:est-zoo}{{5.1}{4}{Estimator consistency: NEES, not miss}{subsection.5.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces EKF / IEKF / UKF compared on the halo-L1 baseline. Thirty-two trials per filter, identical seeds. Mean miss and burn magnitudes are statistically indistinguishable across filters. NEES medians are clustered around $4$--$5$ (target $\approx 6$, dashed green line), but the tail behaviour differs (Section~\ref {sec:ukf-deep}): the EKF/IEKF distributions extend to NEES values above $20$ in the worst trials, while the UKF stays bounded.}}{4}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:est-zoo}{{1}{4}{EKF / IEKF / UKF compared on the halo-L1 baseline. Thirty-two trials per filter, identical seeds. Mean miss and burn magnitudes are statistically indistinguishable across filters. NEES medians are clustered around $4$--$5$ (target $\approx 6$, dashed green line), but the tail behaviour differs (Section~\ref {sec:ukf-deep}): the EKF/IEKF distributions extend to NEES values above $20$ in the worst trials, while the UKF stays bounded}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {5.1.1}UKF deep-dive: distributions, not just means}{5}{subsubsection.5.1.1}\protected@file@percent }
\newlabel{sec:ukf-deep}{{5.1.1}{5}{UKF deep-dive: distributions, not just means}{subsubsection.5.1.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Estimator zoo summary at $n = 32$ trials per filter. NEES target value for a self-consistent filter is $6$ (dimension of the state). On CR3BP the EKF and IEKF have noticeably heavier upper NEES tails than the UKF ($p_{90}$ values $10.2$ vs.\ $6.1$); on SPICE all three filters behave equivalently and are slightly under-confident at NEES $\approx 2.5$.}}{5}{table.caption.4}\protected@file@percent }
\newlabel{tab:est-zoo}{{2}{5}{Estimator zoo summary at $n = 32$ trials per filter. NEES target value for a self-consistent filter is $6$ (dimension of the state). On CR3BP the EKF and IEKF have noticeably heavier upper NEES tails than the UKF ($p_{90}$ values $10.2$ vs.\ $6.1$); on SPICE all three filters behave equivalently and are slightly under-confident at NEES $\approx 2.5$}{table.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-estimator NIS and NEES distributions on the CR3BP halo-L1 baseline (32 trials each). Green band: $\chi ^2$ 95\% interval expected for a self-consistent filter (df = 2 for NIS, df = 6 for NEES). Top row: all three filters' NIS samples sit inside the band, so the \emph  {measurement-residual} statistics check out for each. Bottom row: the EKF and IEKF NEES distributions have a long upper tail extending into the tens; the UKF NEES distribution is much tighter and stays below $\sim \!10$ across all 32 trials. The state-error covariance is what discriminates the filters.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:est-deep-cr3bp}{{2}{5}{Per-estimator NIS and NEES distributions on the CR3BP halo-L1 baseline (32 trials each). Green band: $\chi ^2$ 95\% interval expected for a self-consistent filter (df = 2 for NIS, df = 6 for NEES). Top row: all three filters' NIS samples sit inside the band, so the \emph {measurement-residual} statistics check out for each. Bottom row: the EKF and IEKF NEES distributions have a long upper tail extending into the tens; the UKF NEES distribution is much tighter and stays below $\sim \!10$ across all 32 trials. The state-error covariance is what discriminates the filters}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {paragraph}{Under SPICE the filters converge to the same answer.}{5}{section*.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Outcome CDFs on the same CR3BP estimator-zoo run. Terminal miss (left, log $x$) is statistically indistinguishable across the three filters --- this is what makes the box-plot summary in Figure~\ref {fig:est-zoo} look ``boring''. $\Delta v$ inflation (right) shows a small but consistent UKF advantage in the upper tail, where nonlinearity in the targeting solver tends to amplify EKF/IEKF linearisation errors.}}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:est-deep-cr3bp-cdfs}{{3}{6}{Outcome CDFs on the same CR3BP estimator-zoo run. Terminal miss (left, log $x$) is statistically indistinguishable across the three filters --- this is what makes the box-plot summary in Figure~\ref {fig:est-zoo} look ``boring''. $\Delta v$ inflation (right) shows a small but consistent UKF advantage in the upper tail, where nonlinearity in the targeting solver tends to amplify EKF/IEKF linearisation errors}{figure.caption.6}{}}
